<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="edu.whut.cs.bi.biz.mapper.DiseasePositionMapper">

    <resultMap type="edu.whut.cs.bi.biz.domain.vo.TemplateDiseasePositionVO" id="TemplateDiseasePositionVOResult" extends="DiseasePositionResult">
        <result property="isSelected" column="isSelected"/>
    </resultMap>

    <resultMap type="edu.whut.cs.bi.biz.domain.DiseasePosition" id="DiseasePositionResult">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="code" column="code"/>
        <result property="props" column="props"/>
        <result property="ref1" column="ref1"/>
        <result property="ref2" column="ref2"/>
        <result property="sortOrder" column="sort_order"/>
        <result property="status" column="status"/>
        <result property="delFlag" column="del_flag"/>
        <result property="remark" column="remark"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <sql id="selectDiseasePositionVo">
        select id, name, code, props, ref1, ref2, sort_order, status, del_flag, remark,
               create_by, create_time, update_by, update_time
        from bi_disease_position
    </sql>

    <select id="selectDiseasePositionList" parameterType="edu.whut.cs.bi.biz.domain.DiseasePosition"
            resultMap="DiseasePositionResult">
        <include refid="selectDiseasePositionVo"/>
        <where>
            <if test="name != null and name != ''">AND name like concat('%', #{name}, '%')</if>
            <if test="code != null and code != ''">AND code = #{code}</if>
            <if test="status != null and status != ''">AND status = #{status}</if>
            AND del_flag = '0'
        </where>
        order by sort_order
    </select>

    <select id="selectDiseasePositionById" parameterType="Long" resultMap="DiseasePositionResult">
        <include refid="selectDiseasePositionVo"/>
        where id = #{id} and del_flag = '0'
    </select>

    <insert id="insertDiseasePosition" parameterType="edu.whut.cs.bi.biz.domain.DiseasePosition"
            useGeneratedKeys="true" keyProperty="id">
        insert into bi_disease_position(
        <if test="name != null and name != ''">name,</if>
        <if test="code != null">code,</if>
        <if test="props != null">props,</if>
        <if test="ref1 != null">ref1,</if>
        <if test="ref2 != null">ref2,</if>
        <if test="sortOrder != null">sort_order,</if>
        <if test="status != null">status,</if>
        <if test="remark != null">remark,</if>
        <if test="createBy != null">create_by,</if>
        create_time
        )values(
        <if test="name != null and name != ''">#{name},</if>
        <if test="code != null">#{code},</if>
        <if test="props != null">#{props},</if>
        <if test="ref1 != null">#{ref1},</if>
        <if test="ref2 != null">#{ref2},</if>
        <if test="sortOrder != null">#{sortOrder},</if>
        <if test="status != null">#{status},</if>
        <if test="remark != null">#{remark},</if>
        <if test="createBy != null">#{createBy},</if>
        sysdate()
        )
    </insert>

    <update id="updateDiseasePosition" parameterType="edu.whut.cs.bi.biz.domain.DiseasePosition">
        update bi_disease_position
        <set>
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="code != null">code = #{code},</if>
            <if test="props != null">props = #{props},</if>
            <if test="ref1 != null">ref1 = #{ref1},</if>
            <if test="ref2 != null">ref2 = #{ref2},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            update_time = sysdate()
        </set>
        where id = #{id} and del_flag = '0'
    </update>

    <update id="deleteDiseasePositionById" parameterType="Long">
        update bi_disease_position set del_flag = '2' where id = #{id}
    </update>

    <select id="selectTemplateDiseasePositionList" resultMap="TemplateDiseasePositionVOResult">
        SELECT d.id,
               d.name,
               d.code,
               d.props,
               d.ref1,
               d.ref2,
               d.sort_order,
               d.status,
               d.del_flag,
               d.remark,
               d.create_by,
               d.create_time,
               d.update_by,
               d.update_time,
               CASE WHEN td.template_object_id IS NOT NULL THEN 1 ELSE 0 END AS isSelected
        FROM bi_disease_position d
        LEFT JOIN bi_template_object_disease_position td ON d.id = td.disease_position_id
            AND td.template_object_id = #{templateObjectId}
        <where>
            <if test="diseasePosition.name != null and diseasePosition.name != ''">
                AND d.name like concat('%', #{diseasePosition.name}, '%')
            </if>
            <if test="diseasePosition.status != null and diseasePosition.status != ''">
                AND d.status = #{diseasePosition.status}
            </if>
            <if test="diseasePosition.isSelected != null">
                AND (td.template_object_id IS NOT NULL) = #{diseasePosition.isSelected}
            </if>
            AND d.del_flag = '0'
        </where>
        ORDER BY d.sort_order, d.id
    </select>

</mapper>
